drawon      [00 01] ; Enable menu draw state
drawoff     [00 02] ; Disable the above
varfill     [00 03 short byte]
chkflag     [00 04 $byte $byte addr] ; type abuse
setflag     [00 05 addr byte]
image       [00 06 short] ; Display a portrait
playsfx     [00 07 short]

CALLED      $00000001
DEBUG_MODE  $00000002